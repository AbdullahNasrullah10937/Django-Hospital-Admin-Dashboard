{
  "version": 2,
  "buildCommand": "python manage.py migrate --noinput && python manage.py collectstatic --noinput",
  "builds": [
    {
      "src": "BP_Hospitals/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "BP_Hospitals/wsgi.py"
    }
  ]
}
